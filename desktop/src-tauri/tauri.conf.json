{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ARMusic",
  "version": "1.0.0",
  "identifier": "app.armusic.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ARMusic",
        "width": 1240,
        "height": 780,
        "minWidth": 980,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "category": "Music",
    "shortDescription": "ARMusic desktop player",
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
